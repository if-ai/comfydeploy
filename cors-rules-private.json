[
	{
		"corsRuleName": "privateStandard",
		"allowedOrigins": [
			"https://impactframes.ai",
			"https://www.impactframes.ai",
			"https://comfy.impactframes.ai"
		],
		"allowedHeaders": ["*"],
		"allowedOperations": [
			"s3_get",
			"s3_put",
			"s3_post",
			"s3_delete",
			"s3_head",
			"b2_upload_file",
			"b2_upload_part",
			"b2_download_file_by_name"
		],
		"exposeHeaders": [
			"x-bz-content-sha1",
			"x-bz-file-id",
			"x-bz-file-name",
			"content-length",
			"content-type"
		],
		"maxAgeSeconds": 3600
	}
]
